# first-choice-hub backend (Supabase + Resend). Copy to .env.local and fill in.

# --- Database: isolated `first_choice` schema in the shared wri-suite project ---
# Use the TRANSACTION POOLER connection string (port 6543) from
# Supabase -> Project Settings -> Database -> Connection string -> "Transaction".
# Format: postgresql://postgres.bzfshnjqiiawxzbtxigu:<DB_PASSWORD>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
FC_DATABASE_URL=

# --- Supabase Storage (private bucket fc-work-orders) ---
SUPABASE_URL=https://bzfshnjqiiawxzbtxigu.supabase.co
# Service role (secret) key from Supabase -> Project Settings -> API. Server-only. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Notifications ---
RESEND_API_KEY=
# Verified Resend sender, e.g. "First Choice Hub <noreply@wireach.tools>"
FC_FROM_EMAIL=
# Comma-separated recipients for new/closed work order emails
FC_NOTIFY_EMAILS=
# Optional: Slack incoming webhook for emergency alerts
SLACK_WEBHOOK_URL=
